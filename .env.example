# dokoko — example environment configuration
#
# Copy to .env and fill in values.  These map to the corresponding
# CLI flags when running the web server:
#
#   dokoko-web \
#     --addr              "$DOKOKO_ADDR" \
#     --log               "$DOKOKO_LOG_LEVEL" \
#     --admin-user        "$DOKOKO_ADMIN_USER" \
#     --admin-password    "$DOKOKO_ADMIN_PASSWORD" \
#     --user-name         "$DOKOKO_USER_NAME" \
#     --user-password     "$DOKOKO_USER_PASSWORD" \
#     --allowed-images    "$DOKOKO_ALLOWED_IMAGES" \
#     --config            "$DOKOKO_CONFIG"


# ── Server ────────────────────────────────────────────────────────────────────

# Address and port the HTTP server listens on (default: :8888)
DOKOKO_ADDR=:8888

# Log level: error | warn | info | debug | trace (default: info)
DOKOKO_LOG_LEVEL=info

# Path to the YAML image-variable schema config (default: dokoko.yaml)
DOKOKO_CONFIG=dokoko.yaml


# ── Credentials ───────────────────────────────────────────────────────────────

# Admin account — can manage users, view all tabs, and access all images.
# Change these before exposing dokoko to a network.
DOKOKO_ADMIN_USER=admin
DOKOKO_ADMIN_PASSWORD=changeme

# Default non-admin account — restricted to whitelisted images and terminal only.
DOKOKO_USER_NAME=user
DOKOKO_USER_PASSWORD=changeme

# Comma-separated catalog IDs available to non-admin users.
# Leave empty to allow all images.
DOKOKO_ALLOWED_IMAGES=claudewebd,gemini,codex,opencode


# ── Container API keys ────────────────────────────────────────────────────────
# These are set per-user in the web UI (Environment Variables panel) rather
# than as server-level config.  They are listed here as a reference for which
# keys the bundled images expect.
#
# claudewebd  — requires ANTHROPIC_API_KEY
# gemini      — requires GEMINI_API_KEY
# codex       — requires OPENAI_API_KEY
# opencode    — accepts any of the three (all optional)
#
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
